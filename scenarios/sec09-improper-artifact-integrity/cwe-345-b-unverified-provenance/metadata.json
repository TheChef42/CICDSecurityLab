    "scenarios/sec09-improper-artifact-integrity/cwe-345-b-unverified-provenance/vulnerable/artifact.txt"
  ],
  "fixedFiles": [
    "scenarios/sec09-improper-artifact-integrity/cwe-345-b-unverified-provenance/fixed/deploy-artifact.sh",
    "scenarios/sec09-improper-artifact-integrity/cwe-345-b-unverified-provenance/fixed/artifact.txt",
    "scenarios/sec09-improper-artifact-integrity/cwe-345-b-unverified-provenance/fixed/provenance.json"
  ],
  "remediation": "Require provenance or signature verification and fail closed when verification is missing or invalid.",
  "mappingHints": {
    "keywords": [
      "provenance",
